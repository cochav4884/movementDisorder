<svg width="500" height="500" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">

  <defs>
    <!-- metallic silver gradient -->
    <radialGradient id="silver" cx="50%" cy="35%" r="65%">
      <stop offset="0%" stop-color="#ffffff"></stop>
      <stop offset="35%" stop-color="#d9d9d9"></stop>
      <stop offset="60%" stop-color="#bfbfbf"></stop>
      <stop offset="85%" stop-color="#8c8c8c"></stop>
      <stop offset="100%" stop-color="#e6e6e6"></stop>
    </radialGradient>

    <!-- highlight shine -->
    <radialGradient id="shine" cx="35%" cy="25%" r="40%">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0.7"></stop>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"></stop>
    </radialGradient>

  </defs>

  <!-- metallic button -->
  <circle cx="250" cy="250" r="240" fill="url(#silver)" stroke="#777" stroke-width="4"></circle>

  <!-- reflective shine -->
  <ellipse cx="200" cy="170" rx="140" ry="90" fill="url(#shine)"></ellipse>

</svg>