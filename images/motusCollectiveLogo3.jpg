<svg width="600" height="600" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">

  <defs>

    <!-- outer metal rim -->
    <radialGradient id="rim" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#f5f5f5"></stop>
      <stop offset="40%" stop-color="#cfcfcf"></stop>
      <stop offset="70%" stop-color="#9e9e9e"></stop>
      <stop offset="100%" stop-color="#e6e6e6"></stop>
    </radialGradient>

    <!-- inner metal face -->
    <radialGradient id="face" cx="50%" cy="35%" r="65%">
      <stop offset="0%" stop-color="#ffffff"></stop>
      <stop offset="35%" stop-color="#e3e3e3"></stop>
      <stop offset="60%" stop-color="#bfbfbf"></stop>
      <stop offset="90%" stop-color="#8f8f8f"></stop>
      <stop offset="100%" stop-color="#d9d9d9"></stop>
    </radialGradient>

    <!-- shine highlight -->
    <radialGradient id="shine" cx="30%" cy="25%" r="45%">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0.75"></stop>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"></stop>
    </radialGradient>

  </defs>

  <!-- metal rim -->
  <circle cx="300" cy="300" r="290" fill="url(#rim)"></circle>

  <!-- button face -->
  <circle cx="300" cy="300" r="255" fill="url(#face)"></circle>

  <!-- highlight -->
  <ellipse cx="250" cy="210" rx="170" ry="110" fill="url(#shine)"></ellipse>

</svg>